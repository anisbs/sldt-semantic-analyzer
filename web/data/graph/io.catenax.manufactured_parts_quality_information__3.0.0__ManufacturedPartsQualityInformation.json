    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#ManufacturedPartsQualityInformation",
      "label": "ManufacturedPartsQualityInformation",
      "kind": "Aspect",
      "preferredName": "Manufactured Parts Quality Information Aspect Model",
      "description": "For Catena-X(CX) business case Quality Management. Supported technical features: delta update feature, meta information feature and additionalInformationList key-value pairs. The supported model features are described in detail in the Catena-X Quality KIT. Manufactured parts quality information data model is used to exchange information how a list of parts was manufactured with focus on information that might help to better understand the root cause for the quality task."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#manufacturedParts",
      "label": "manufacturedParts",
      "kind": "Property",
      "preferredName": "Manufactured Parts",
      "description": "A list of manufactured parts and their properties"
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#productionDate",
      "label": "productionDate",
      "kind": "Property",
      "preferredName": "Production Date",
      "description": "Date of production for this specific part."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#hasBeenReworked",
      "label": "hasBeenReworked",
      "kind": "Property",
      "preferredName": "Has Been Reworked",
      "description": "Indicator whether this part was reworked during manufacturing."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#numberOfConductedEndOfLineTests",
      "label": "numberOfConductedEndOfLineTests",
      "kind": "Property",
      "preferredName": "Number Of Conducted End-Of-Line Tests",
      "description": "Number of conducted end-of-production-line tests. For some production lines there are several tests to be conducted (electrical tests, mechanical tests, functional tests, ...)."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#ManufacturedPartsList",
      "label": "ManufacturedPartsList",
      "kind": "Characteristic",
      "preferredName": "Manufactured Parts List",
      "description": "A list of manufactured parts."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#ManufacturedPart",
      "label": "ManufacturedPart",
      "kind": "Entity",
      "preferredName": "Manufactured Part",
      "description": "Manufacturing information of one part. Important properties to identify the manufactured part are coming from central shared quality core model. Besides that there is a key:value list to exchange additional, non-standardized properties for this part."
    },
    {
      "id": "urn:samm:io.catenax.manufactured_parts_quality_information:3.0.0#PositiveNumber",
      "label": "PositiveNumber",
      "kind": "Characteristic",
      "preferredName": "Positive Number Characteristic",
      "description": "This Characteristic describes a positive number. 0 is not included."
    }
