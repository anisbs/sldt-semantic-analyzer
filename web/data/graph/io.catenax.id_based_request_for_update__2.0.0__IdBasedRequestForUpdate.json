  "nodes": [
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#IdBasedRequestForUpdate",
      "label": "IdBasedRequestForUpdate",
      "kind": "Aspect",
      "preferredName": "ID Based Request For Update",
      "description": "The requirements for a request for update from another Catena-X Partner of a specific entity.\nIf within the payload, no specific object type is defined (Payload empty), than an update of all objects within the sender reciever relation is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#materialDemand",
      "label": "materialDemand",
      "kind": "Property",
      "preferredName": "Material Demand List",
      "description": "Material demands the supplier requests an update for.\nIf within the array, no specific ID (array empty), than an update of all IDs is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#weekBasedCapacityGroup",
      "label": "weekBasedCapacityGroup",
      "kind": "Property",
      "preferredName": "Week Based Capacity Group List",
      "description": "Capacity groups the customer requests an update for.\nIf within the array, no specific ID (array empty), than an update of all IDs is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#materialDemandId",
      "label": "materialDemandId",
      "kind": "Property",
      "preferredName": "Material Demand ID",
      "description": "The Material Demand ID uniquely identifies the material demand the supplier requests an update for within the business relationship between the customer and its supplier."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#changedAt",
      "label": "changedAt",
      "kind": "Property",
      "preferredName": "Changed At",
      "description": "Point in time of the last update known to the requesting business partner. If the requested entity has been changed more recently, the requested party should resend the data. If the changedAt property is not given, the latest entity should be send without precondition."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#capacityGroupId",
      "label": "capacityGroupId",
      "kind": "Property",
      "preferredName": "Capacity Group ID",
      "description": "The Capacity Group ID uniquely identifies the capacity group the supplier requests an update for within the business relationship between the supplier and its customer."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#MaterialDemandCharacteristic",
      "label": "MaterialDemandCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Material Demand Characteristic",
      "description": "A list of material demand UUIDs without duplicates an update is requested for."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#WeekBasedCapacityGroupCharacteristic",
      "label": "WeekBasedCapacityGroupCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Week Based Capacity Group Characteristic",
      "description": "A list of capacity group UUIDs without duplicates an update is requested for."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#MaterialDemandEntity",
      "label": "MaterialDemandEntity",
      "kind": "Entity",
      "preferredName": "Material Demand Entity",
      "description": "Encapsulates the information that is necessary for an update request."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:2.0.0#WeekBasedCapacityGroupEntity",
