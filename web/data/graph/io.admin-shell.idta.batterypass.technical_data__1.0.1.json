      "label": "BatteryMassMeasurable",
      "kind": "Characteristic",
      "preferredName": null,
      "description": "Weight of the battery\nEUBR: Annex XIII (1a) - Annex VI Part A (5)"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#temperatureRangeIdleStateUpperBoundary",
      "label": "temperatureRangeIdleStateUpperBoundary",
      "kind": "Property",
      "preferredName": "temperature range idle state (upper boundary)",
      "description": "Upper boundary of the surrounding temperature range, which the battery can safely withstand."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#temperatureRangeIdleStateLowerBoundary",
      "label": "temperatureRangeIdleStateLowerBoundary",
      "kind": "Property",
      "preferredName": "temperature range idle state (lower boundary)",
      "description": "Lower boundary of the surrounding temperature range, which the battery can safely withstand."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#maximumPermittedBatteryPower",
      "label": "maximumPermittedBatteryPower",
      "kind": "Property",
      "preferredName": "maximum permitted battery power",
      "description": "Maximum permitted power the battery is rated for, includes the data relevant for power limits."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#initialRoundTripEnergyEfficiency",
      "label": "initialRoundTripEnergyEfficiency",
      "kind": "Property",
      "preferredName": "initial round trip energy efficiency",
      "description": "Initial round trip energy efficiency means the ratio of the net energy delivered by a battery during a discharge test to the total energy required to restore the initial State of Charge by a standard charge."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#initialSelfDischargingRate",
      "label": "initialSelfDischargingRate",
      "kind": "Property",
      "preferredName": "initial self discharging rate",
      "description": "Initial self-discharge in % of capacity per unit of time in defined conditions (temperature range etc) as pre-use metric."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#initialInternalResistanceAtBatteryCellLevel",
      "label": "initialInternalResistanceAtBatteryCellLevel",
      "kind": "Property",
      "preferredName": "initial internal resistance at battery cell level",
      "description": "\n  Internal battery cell and pack resistance / Internal resistance (in Ohm).\n  \n  Measure of a battery cell’s opposition to current flow at the beginning of its operational life, affecting its performance, efficiency, and heat generation (internal resistance means the absolute value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse).\n  "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#initialInternalResistanceAtBatteryPackLevel",
      "label": "initialInternalResistanceAtBatteryPackLevel",
      "kind": "Property",
      "preferredName": "initial internal resistance at battery pack level",
      "description": "\n  Initial (Pre-Use) internal resistance at battery pack level.\n  \n  Measure of opposition to current flow in an entire battery pack at the start of its operational life, affecting overall performance, efficiency, and heat generation (internal resistance means the absolute value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse).\n  "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#initialInternalResistanceAtBatteryModuleLevel",
      "label": "initialInternalResistanceAtBatteryModuleLevel",
      "kind": "Property",
      "preferredName": "initial internal resistance at battery module level",
      "description": "\n  Initial internal resistance at battery module level.\n  \n  Initial internal resistance means the absolute beginning value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse.\n  "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#internalResistanceIncreaseAtBatteryCellLevel",
      "label": "internalResistanceIncreaseAtBatteryCellLevel",
      "kind": "Property",
      "preferredName": "internal resistance increase at battery cell level",
      "description": "Internal resistance increase at battery cell level."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#internalResistanceIncreaseAtBatteryPackLevel",
      "label": "internalResistanceIncreaseAtBatteryPackLevel",
      "kind": "Property",
      "preferredName": "internal resistance increase at battery pack level",
      "description": "'Internal resistance increase at battery pack level' defined by 'increase of internal resistance in % as calculated from current and initial values (calculated from initial and current internal resistance on battery pack level)."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#internalResistanceIncreaseAtBatteryModuleLevel",
      "label": "internalResistanceIncreaseAtBatteryModuleLevel",
      "kind": "Property",
      "preferredName": "internal resistance increase at battery module level",
      "description": "Internal resistance increase at battery module level level' defined by 'internal resistance increase on battery module level, calculated from initial and current internal resistance on battery module level."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#nominalVoltage",
      "label": "nominalVoltage",
      "kind": "Property",
      "preferredName": "voltage - NOM",
      "description": "Nominal voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.11"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#minimumVoltage",
      "label": "minimumVoltage",
      "kind": "Property",
      "preferredName": "voltage - MIN",
      "description": "Minimum voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.9"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#maximumVoltage",
      "label": "maximumVoltage",
      "kind": "Property",
      "preferredName": "voltage - MAX",
      "description": "Maximum voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.10"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#ratedEnergy",
      "label": "ratedEnergy",
      "kind": "Property",
      "preferredName": "rated energy",
      "description": "The certified usable battery energy is the usable battery energy according to the procedure in the UN GTR No 22 as determined during the certification of the vehicle.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.5"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#ratedCapacity",
      "label": "ratedCapacity",
      "kind": "Property",
      "preferredName": "rated capacity",
      "description": "Rated capacity is the total number of ampere-hours (Ah) that can be withdrawn from a fully charged battery under reference conditions (see BattReg Annex IV (1)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.2"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#powerFade",
      "label": "powerFade",
      "kind": "Property",
      "preferredName": null,
      "description": "Power fade (in %) means the decrease over time and upon usage in the amount of power that a battery can deliver at the rated voltage. (see BattReg Annex IV (4)).\n\nPower fade should be calculated using original and remaining power capability following the formula below:\nPfade(x) = (1-P(x)) / PBOL\" 100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nP(x) \tis the power capability at aging parameter x;\nPBOL \tis the power capability at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#powerCapabilityRatio",
      "label": "powerCapabilityRatio",
      "kind": "Property",
      "preferredName": "power capability ratio",
      "description": "The nominal battery power is the suitable approximate value of the power capability used to designate or identify the battery, while the battery energy is determined in reference conditions to be defined.\n   \n   DIN DKE Spec 99100 chapter reference: 6.7.3.6\n   "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#capacityFade",
      "label": "capacityFade",
      "kind": "Property",
      "preferredName": "capacity fade",
      "description": "The capacity fade is the Decrease over time and upon usage in the amount of charge that a battery can deliver at the rated voltage, with respect to the original rated capacity (see BattReg Annex IV (2)) as declared by the manufacturer.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#energyRoundTripEfficiencyFade",
      "label": "energyRoundTripEfficiencyFade",
      "kind": "Property",
      "preferredName": "energy round trip efficiency fade",
      "description": "Energy round trip efficiency fade is the decrease of round trip energy efficiency as percentage.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.5"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#expectedNumberOfCycles",
      "label": "expectedNumberOfCycles",
      "kind": "Property",
      "preferredName": "expected number of cycles",
      "description": "Expected battery lifetime expressed in cycles.\nThe exception for non-cycle applications in Article 10 appears sensible, but is not included in the Annex XIII provision.\nThe data attribute is defined by measurement conditions of the cycle-life test such as the C-Rate (see below) and the depth of discharge in the cycle-life test\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.3"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#roundTripEfficiencyAt50PercentCycleLife",
      "label": "roundTripEfficiencyAt50PercentCycleLife",
      "kind": "Property",
      "preferredName": "round trip efficiency at 50 percent cycle life",
      "description": "Initial round trip energy efficiency shall be measured at reference conditions that include the specification of 50 % of cycle-life.\n\nTest methods and reference conditions should separately consider non-cycle applications and batteries with very long cycle-life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.3\n"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#expectedLifetime",
      "label": "expectedLifetime",
      "kind": "Property",
      "preferredName": "expected lifetime in calendar years",
      "description": "The battery passport must include information about the expected battery lifetime in calendar years.\n\nThe update interval must be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.2"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#capacityThresholdForExhaustion",
      "label": "capacityThresholdForExhaustion",
      "kind": "Property",
      "preferredName": "capacity threshold for exhaustion",
      "description": "The percentage of SOCE, above which the battery is still considered operational as EV battery in its current life, as provided by the economic operator.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.9"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#cRateLifeCycleTest",
      "label": "cRateLifeCycleTest",
      "kind": "Property",
      "preferredName": "C-rate life cycle test",
      "description": "The C-rate should be provided separately for both the charge and discharge of the battery, if applicable.\n\nThe exception for non-cycle applications as mentioned in \"Expected lifetime: Number of charge-discharge cycles\" should apply to this data attribute as well.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.6"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#atSoC",
      "label": "atSoC",
      "kind": "Property",
      "preferredName": "state of charge (SoC) in percent",
      "description": "Available capacity in a battery expressed as a percentage of remaining capacity.\n\nPower capability shall be measured at reference conditions, which must include measurements at 80% and 20% state of charge for EV and industrial batteries."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#powerCapabilityAt",
      "label": "powerCapabilityAt",
      "kind": "Property",
      "preferredName": "power capability",
      "description": "Power capability."
    },
