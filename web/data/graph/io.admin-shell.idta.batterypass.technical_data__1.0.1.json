    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#warrantyInformation",
      "label": "warrantyInformation",
      "kind": "Property",
      "preferredName": "identifier of the manufacturer",
      "description": "\n   The battery passport must include information about the period for which the commercial warranty applies.\n   \n   DIN DKE Spec chapter reference: 6.1.3.4\n   "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#manufacturerIdentifier",
      "label": "manufacturerIdentifier",
      "kind": "Property",
      "preferredName": "identifier of the manufacturer",
      "description": "A battery passport must include information identifying the manufacturer.\n\n DIN DKE Spec 99100 chapter reference: 6.1.2.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#warrantyPeriod",
      "label": "warrantyPeriod",
      "kind": "Property",
      "preferredName": "warranty period",
      "description": "\n   The battery passport must include information about the period for which the commercial warranty applies.\n   \n   DIN DKE Spec chapter reference: 6.1.3.4\n   \n   The format shall be provided in ISO 8601 Notation for duration.\n   "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#batteryCategory",
      "label": "batteryCategory",
      "kind": "Property",
      "preferredName": "BatteryCategory",
      "description": "Categories relevant for the battery passport: LMT battery, electric vehicle battery, stationary or other industrial battery >2kWh.\n\nDIN DKE Spec chapter reference: 6.1.3.5"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#batteryMass",
      "label": "batteryMass",
      "kind": "Property",
      "preferredName": "battery mass",
      "description": "Mass of the entire battery in kilograms. Voluntary: if the battery is defined on pack or module level: also weight of the modules and/or cells.\n\nDIN DKE Spec chapter reference: 6.1.3.6"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.technical_data:1.0.1#WarrantyInformationCharacteristic",
