  "nodes": [
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#ShortTermMaterialDemand",
      "label": "ShortTermMaterialDemand",
      "kind": "Aspect",
      "preferredName": "Short Term Material Demand",
      "description": "The requirements of a customer towards a specific supplier for a specific material. Each material demand is unique by its Customer, Supplier and Material Number."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demandSeries",
      "label": "demandSeries",
      "kind": "Property",
      "preferredName": "Demand Series",
      "description": "The demands for a dedicated material in a given time period, distinguished by their demand location and demand category."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#materialGlobalAssetId",
      "label": "materialGlobalAssetId",
      "kind": "Property",
      "preferredName": "UUID of the Part Type Twin",
      "description": "Identifier used uniquely to identify part type twin."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demands",
      "label": "demands",
      "kind": "Property",
      "preferredName": "Demands",
      "description": "A time series on a daily basis along a given time period to describe the demand values for this demand series."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demandCategory",
      "label": "demandCategory",
      "kind": "Property",
      "preferredName": "Demand Category",
      "description": "Type of demand for this demand series."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#expectedSupplierLocationBpns",
      "label": "expectedSupplierLocationBpns",
      "kind": "Property",
      "preferredName": "Expected Supplier Location",
      "description": "The Business Partner Number Site (BPNS) of the site from where the customer expects the supplier to fulfill the demands of the demand series. The value is used for informational purposes only and is therefore not binding for the supplier."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#customerLocationBpns",
      "label": "customerLocationBpns",
      "kind": "Property",
      "preferredName": "Customer Location",
      "description": "The Business Partner Number Site (BPNS) of the site at which the customer needs the specified material for this demand series."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#lastUpdatedOnDateTime",
      "label": "lastUpdatedOnDateTime",
      "kind": "Property",
      "preferredName": "Lasted Updated on Date",
      "description": "Date and time at which the DemandSeries has been updated by the reporting partner's system. Date and time are set according to a timezone."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demand",
      "label": "demand",
      "kind": "Property",
      "preferredName": "Demand",
      "description": "Quantity of materials required on a specific day. This demand is not a call-off and should be as close as possible to the actual production program."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#day",
      "label": "day",
      "kind": "Property",
      "preferredName": "Day",
      "description": "Day of the demanded quantity."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demandCategoryCode",
      "label": "demandCategoryCode",
      "kind": "Property",
      "preferredName": "Demand Category Code",
      "description": "The code identifying a demand category."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#demandCategoryName",
      "label": "demandCategoryName",
      "kind": "Property",
      "preferredName": "Demand Category Name",
      "description": "The name describing a demand category."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#DemandSeriesSet",
      "label": "DemandSeriesSet",
      "kind": "Characteristic",
      "preferredName": "Demand Series Set",
      "description": "A set of demand series belonging to a certain material demand. Each demand series in the set must have a unique combination of customer location and demand category."
    },
    {
      "id": "urn:samm:io.catenax.short_term_material_demand:1.0.0#DemandSeries",
      "label": "DemandSeries",
      "kind": "Entity",
      "preferredName": "Demand Series",
      "description": "Encapsulates the demand series related information."
    },
    {
