      "description": "Additional, customer specific information for customer's use only. This field contains customer data that is transmitted in the PCI segment (qual-ifier 16 or 3) of the customer call-off."
    },
    {
      "id": "urn:samm:io.catenax.global_transport_label:1.0.0#supplierId",
      "label": "supplierId",
      "kind": "Property",
      "preferredName": "Supplier ID",
      "description": "The supplier ID is filled in if the actual sender of the goods differs from the actual supplier. In other words, the supplier ID provides information on where the goods are actually delivered from - the physical sender of the goods. A supplier ID is assigned by the ordering company for this purpose. This is not created or hosted centrally, similar to the DUNS number. It is freely selectable and can therefore be freely designed in terms of syntax.ID number from the supplier."
    },
    {
      "id": "urn:samm:io.catenax.global_transport_label:1.0.0#unloadingPoint",
      "label": "unloadingPoint",
      "kind": "Property",
      "preferredName": "Unloading Point",
      "description": "Unloading point where the means of transport is being unloaded."
    },
    {
      "id": "urn:samm:io.catenax.global_transport_label:1.0.0#internalDestination",
      "label": "internalDestination",
