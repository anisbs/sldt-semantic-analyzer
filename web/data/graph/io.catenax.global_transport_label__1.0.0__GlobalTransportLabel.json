    {
      "id": "urn:samm:io.catenax.global_transport_label:1.0.0#dateCategoryInformation",
      "label": "dateCategoryInformation",
      "kind": "Property",
      "preferredName": "Date Category Information",
      "description": "On Master and Mixed Labels attached to loading units: Package type, ship-ping date, number of inner packages\nThe following applies to inner packages and simplified loading units:\n- If there is an expiry date, it must be printed. The expiry date must be preceded by the letter \"E\".\n- If there is no expiry date, and if the shipping date is known at the time of printing the label, the shipping date should be printed. The shipping date must be preceded by the letter \"S\".\n- If none of the above dates are known or apply, the production date should be printed. The production date must be preceded by the letter \"P\"."
    },
    {
      "id": "urn:samm:io.catenax.global_transport_label:1.0.0#batchNumber",
