  "nodes": [
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#ReturnRequest",
      "label": "ReturnRequest",
      "kind": "Aspect",
      "preferredName": "return request",
      "description": "Aspect to indicate if there is a return request for a product."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#needsReturn",
      "label": "needsReturn",
      "kind": "Property",
      "preferredName": "needs return",
      "description": "Describes the fact whether a vehicle, assembly or part needs to be returned to requestor."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#returnConditions",
      "label": "returnConditions",
      "kind": "Property",
      "preferredName": "return conditions",
      "description": "Describes WHY a vehicle, assembly or part needs to be returned to the requestor and under which conditions."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#requestDate",
      "label": "requestDate",
      "kind": "Property",
      "preferredName": "request date",
      "description": "Describes date when the return request was placed."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#latestReturnDate",
      "label": "latestReturnDate",
      "kind": "Property",
      "preferredName": "latest return date",
      "description": "Describes until when the return request is valid."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#productConditions",
      "label": "productConditions",
      "kind": "Property",
      "preferredName": "product conditions",
      "description": "textual description of the product conditions"
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#title",
      "label": "title",
      "kind": "Property",
      "preferredName": "title",
      "description": "The request name to be used by the buyer to navigate through the list of demand requests."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#marketplaceProduct",
      "label": "marketplaceProduct",
      "kind": "Property",
      "preferredName": "marketplace product",
      "description": "The description of the product within the marketplace that might differ from the digital twin."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#quantity",
      "label": "quantity",
      "kind": "Property",
      "preferredName": "quantity",
      "description": "The desired quantity of the on the marketplace offered product in SKU."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#unitOfMeasure",
      "label": "unitOfMeasure",
      "kind": "Property",
      "preferredName": "unit of measure",
      "description": "The unit of measure (related to quantity)."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#validityPeriod",
      "label": "validityPeriod",
      "kind": "Property",
      "preferredName": "validity period",
      "description": "Specifies the time period when the need exists"
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#priceRange",
      "label": "priceRange",
      "kind": "Property",
      "preferredName": "price range",
      "description": "Range of monetary values."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#isRecall",
      "label": "isRecall",
      "kind": "Property",
      "preferredName": "is recall",
      "description": "Depicts if the manufacturer issued a recall (e.g. for security reasons). In concjunction with property needsReturn it can be expressed if the item has to be returned or can directly be destroyed."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#startDate",
      "label": "startDate",
      "kind": "Property",
      "preferredName": "start date",
      "description": "The first day of the period"
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#endDate",
      "label": "endDate",
      "kind": "Property",
      "preferredName": "end date",
      "description": "The last day of the period."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#minPrice",
      "label": "minPrice",
      "kind": "Property",
      "preferredName": "minimum price",
      "description": "The minimum price that a buyer is ready to pay to get an item (motivating sellers to sell)."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#maxPrice",
      "label": "maxPrice",
      "kind": "Property",
      "preferredName": "maximum price",
      "description": "The maximum price until which a demand request is relevant."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.2#value",
      "label": "value",
