      "description": "Entity defining a range of dates to define a time period."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#IdentificationEntity",
      "label": "IdentificationEntity",
      "kind": "Entity",
      "preferredName": "identification entity",
