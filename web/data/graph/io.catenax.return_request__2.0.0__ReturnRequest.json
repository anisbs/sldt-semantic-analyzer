  "nodes": [
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#ReturnRequest",
      "label": "ReturnRequest",
      "kind": "Aspect",
      "preferredName": "return request",
      "description": "Aspect to indicate if there is a return request for a product."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#needsReturn",
      "label": "needsReturn",
      "kind": "Property",
      "preferredName": "needs return",
      "description": "Describes the fact whether a vehicle, assembly or part needs to be returned to requestor."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#returnConditions",
      "label": "returnConditions",
      "kind": "Property",
      "preferredName": "return conditions",
      "description": "Describes WHY a vehicle, assembly or part needs to be returned to the requestor and under which conditions."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#requestDate",
      "label": "requestDate",
      "kind": "Property",
      "preferredName": "request date",
      "description": "Describes date when the return request was placed."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#latestReturnDate",
      "label": "latestReturnDate",
      "kind": "Property",
      "preferredName": "latest return date",
      "description": "Describes until when the return request is valid."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#productConditions",
      "label": "productConditions",
      "kind": "Property",
      "preferredName": "product conditions",
      "description": "textual description of the product conditions"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#marketplaceProduct",
      "label": "marketplaceProduct",
      "kind": "Property",
      "preferredName": "marketplace product",
      "description": "The description of the product within the marketplace that might differ from the digital twin."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#quantity",
      "label": "quantity",
      "kind": "Property",
      "preferredName": "quantity",
      "description": "The desired quantity of the on the marketplace offered product in SKU."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#validityPeriod",
      "label": "validityPeriod",
      "kind": "Property",
      "preferredName": "validity period",
      "description": "Specifies the time period when the need exists"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#isRecall",
      "label": "isRecall",
      "kind": "Property",
      "preferredName": "is recall",
      "description": "Depicts if the manufacturer issued a recall (e.g. for security reasons). In conjunction with property needsReturn it can be expressed if the item has to be returned or can directly be destroyed."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#identification",
      "label": "identification",
      "kind": "Property",
      "preferredName": "identification",
      "description": "The unique identifier of the product (via manufacturingPartID, OeNumber and/or serialNumber)\n"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#deliveryAddress",
      "label": "deliveryAddress",
      "kind": "Property",
      "preferredName": "delivery address",
      "description": "The address that the product should be delivered to"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#areaOfUsage",
      "label": "areaOfUsage",
      "kind": "Property",
      "preferredName": "area of usage",
      "description": "Information, in which countries/areas the component has been in use"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#arrivalDateAtCustomer",
      "label": "arrivalDateAtCustomer",
      "kind": "Property",
      "preferredName": "arrival date at customer",
      "description": "Until when should the product arrive (if known)"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#missingParts",
      "label": "missingParts",
      "kind": "Property",
      "preferredName": "missing parts",
      "description": "Completeness of the product, e.g. missing parts are not acceptable."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#dismantled",
      "label": "dismantled",
      "kind": "Property",
      "preferredName": "dismantled",
      "description": "Information on whether the product has been dismantled."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#mechanicalDamage",
      "label": "mechanicalDamage",
      "kind": "Property",
      "preferredName": "mechanical damage",
      "description": "Information on mechanical damage to the part, e.g. two broken ribs or part deformation indicate mechanical damage."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#corroded",
      "label": "corroded",
      "kind": "Property",
      "preferredName": "corroded",
      "description": "Information on whether the product has corrosion."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#discolored",
      "label": "discolored",
      "kind": "Property",
      "preferredName": "discolored",
      "description": "Information on whether the product has been discoloured."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#mileage",
      "label": "mileage",
      "kind": "Property",
      "preferredName": "mileage",
      "description": "Current mileage of the component"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#startDate",
      "label": "startDate",
      "kind": "Property",
      "preferredName": "start date",
      "description": "The first day of the period"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#endDate",
      "label": "endDate",
      "kind": "Property",
      "preferredName": "end date",
      "description": "The last day of the period."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#DateTimestamp",
      "label": "DateTimestamp",
      "kind": "Characteristic",
      "preferredName": "date timestamp",
      "description": "Timestamp for dates"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#ProductConditionsCharacteristic",
      "label": "ProductConditionsCharacteristic",
      "kind": "Characteristic",
      "preferredName": "product conditions characteristic",
      "description": "Criteria describing the state of a product on the marketplace."
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#IdentificationCharacteristic",
      "label": "IdentificationCharacteristic",
      "kind": "Characteristic",
      "preferredName": "identification characteristic",
      "description": "The unique identifier of the product (via manufacturingPartID, OeNumber and/or serialNumber)\n"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#TimePeriod",
      "label": "TimePeriod",
      "kind": "Characteristic",
      "preferredName": "time period",
      "description": "Depicts a time period by specifying start and end date"
    },
    {
      "id": "urn:samm:io.catenax.return_request:2.0.0#ProductConditionsEntity",
