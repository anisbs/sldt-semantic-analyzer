  "nodes": [
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#ProductCondition",
      "label": "ProductCondition",
      "kind": "Aspect",
      "preferredName": "product condition",
      "description": "Covers all battery lifetime relevant properties."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#informationOnAccidents",
      "label": "informationOnAccidents",
      "kind": "Property",
      "preferredName": "information on accidents",
      "description": "The battery passport must contain information and data resulting from its use such as accidents. \n\nDIN DKE Spec 99100 chapter reference: 6.7.8.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#lastUpdate",
      "label": "lastUpdate",
      "kind": "Property",
      "preferredName": "last update",
      "description": "Timestamp for dynamic data attributes show the last update time.\n\n   Defined time within a time range, measured from the start time of the time range.\n   "
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#energyThroughput",
      "label": "energyThroughput",
      "kind": "Property",
      "preferredName": "energy throughput",
      "description": "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.7"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#energyThroughputValue",
      "label": "energyThroughputValue",
      "kind": "Property",
      "preferredName": "energy throughput",
      "description": "Overall sum of the energy throughput over the battery lifetime (data attribute should be reported as measured for further potential processing. In addition, the normalisation by usable battery energy could add a further useful value that ensures comparability among battery sizes)."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#capacityThroughput",
      "label": "capacityThroughput",
      "kind": "Property",
      "preferredName": null,
      "description": "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.8"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#capacityThroughputValue",
      "label": "capacityThroughputValue",
      "kind": "Property",
      "preferredName": "capacity throughput",
      "description": "Overall sum of the capacity throughput over the battery lifetime (data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity could add a further useful value that ensures comparability among battery sizes)."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#numberOfFullCycles",
      "label": "numberOfFullCycles",
      "kind": "Property",
      "preferredName": "number of full cycles",
      "description": "Number of (full) charging and discharging cycles.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#numberOfFullCyclesValue",
      "label": "numberOfFullCyclesValue",
      "kind": "Property",
      "preferredName": "number of full cycles",
      "description": "Total count of times a battery has been fully charged from empty to full capacity and then fully discharged, used as an indicator of the battery's usage and lifespan."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#stateOfCertifiedEnergy",
      "label": "stateOfCertifiedEnergy",
      "kind": "Property",
      "preferredName": "SOCE",
      "description": "Definition based on UNECE GTR 22: The measured or on-board UBE performance at a specific point in its lifetime, expressed as a percentage of the certified usable battery energy.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.7"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#stateOfCertifiedEnergyValue",
      "label": "stateOfCertifiedEnergyValue",
      "kind": "Property",
      "preferredName": "state of certified energy",
      "description": "Measured or on-board UBE performance at a specific point in its lifetime, expressed as a percentage of the certified usable battery energy."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingEnergy",
      "label": "remainingEnergy",
      "kind": "Property",
      "preferredName": "remaining energy",
      "description": "Definition from UNECE GTR 22, applicable only to EVs.\nThe energy supplied by the battery from the beginning of the test procedure used for certification until the applicable break-off criterion of the test procedure used for certification is reached.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.6"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingEnergyValue",
      "label": "remainingEnergyValue",
      "kind": "Property",
      "preferredName": "remaining energy",
      "description": "UBE determined at the present point in the lifetime of the vehicle by the test procedure used for certification."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingCapacity",
      "label": "remainingCapacity",
      "kind": "Property",
      "preferredName": "remaining capacity",
      "description": "The in-use data attribute on capacity, corresponding with the definition of rated capacity.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.3"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingCapacityValue",
      "label": "remainingCapacityValue",
      "kind": "Property",
      "preferredName": "remaining capacity",
      "description": "In-use data attribute on capacity, corresponding with the definition of rated capacity."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#negativeEvents",
      "label": "negativeEvents",
      "kind": "Property",
      "preferredName": "negative events",
      "description": "The battery passport must contain information and data resulting from its use such as accidents. \n\nDIN DKE Spec 99100 chapter reference: 6.7.8.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#negativeEventValue",
      "label": "negativeEventValue",
      "kind": "Property",
      "preferredName": "negative event",
      "description": "Negative event, such as an accident. No further definition provided by regulation."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#temperatureInformation",
      "label": "temperatureInformation",
      "kind": "Property",
      "preferredName": "temperature information",
      "description": "The battery passport must include periodically recorded information on the operating environmental conditions, including temperature.\n\nDIN DKE Spec 99100 chapter reference: 6.7.7.5 - 8"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#timeExtremeHighTemp",
      "label": "timeExtremeHighTemp",
      "kind": "Property",
      "preferredName": "time extreme high temperature",
      "description": "Cumulated time spent above the given upper boundary of temperature."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#timeExtremeLowTemp",
      "label": "timeExtremeLowTemp",
      "kind": "Property",
      "preferredName": "time extreme low temperature",
      "description": "Cumulated time spent below the given lower boundary of temperature."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#timeExtremeHighTempCharging",
      "label": "timeExtremeHighTempCharging",
      "kind": "Property",
      "preferredName": "time extreme high temperature charging",
      "description": "Cumulated time spent above the given upper boundary of temperature during Charging."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#timeExtremeLowTempCharging",
      "label": "timeExtremeLowTempCharging",
      "kind": "Property",
      "preferredName": "time extreme low temperature charging",
      "description": "Cumulated time spent below the given lower boundary of temperature during charging."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingPowerCapability",
      "label": "remainingPowerCapability",
      "kind": "Property",
      "preferredName": "remaining power capability",
      "description": "Original power capability (in Watts) and limits, with temperature range when relevant.\n- The amount of energy that a battery is capable to provide over a given period of time under reference conditions.\n- Power capability at 80% and 20% state of charge.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.3"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingPowerCapabilityValue",
      "label": "remainingPowerCapabilityValue",
      "kind": "Property",
      "preferredName": "remaining power capability value",
      "description": "Remaining power capability value."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#atSoC",
      "label": "atSoC",
      "kind": "Property",
      "preferredName": "at SoC",
      "description": "Available capacity in a battery expressed as a percentage of remaining capacity."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#powerCapabilityAt",
      "label": "powerCapabilityAt",
      "kind": "Property",
      "preferredName": "power capability at",
      "description": "Defined by 'pre-use power capability (definition of power capability as given in Battery Regulation."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#rPCLastUpdated",
      "label": "rPCLastUpdated",
      "kind": "Property",
      "preferredName": "RPC last updated",
      "description": "RPC last updated."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#evolutionOfSelfDischarge",
      "label": "evolutionOfSelfDischarge",
      "kind": "Property",
      "preferredName": "evolution of self discharge",
      "description": "Evolution of self-discharge rates is the change of self-discharge over time and usage, as percentage calculated from the initial and current self-discharge rate.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.8"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#evolutionOfSelfDischargeValue",
      "label": "evolutionOfSelfDischargeValue",
      "kind": "Property",
      "preferredName": "evolution of self discharge value",
      "description": "Total count of times a battery has been fully charged from empty to full capacity and then fully discharged, used as an indicator of the battery's usage and lifespan."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#currentSelfDischargingRate",
      "label": "currentSelfDischargingRate",
      "kind": "Property",
      "preferredName": "current self discharge rate",
      "description": "The current self-discharge rate is the change of the self-discharge rate in an idle state of the battery in reference conditions (temperature etc.) at aging parameter x, e.g. after a certain amount of storage time or, number of cycles.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.7"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#currentSelfDischargingRateValue",
      "label": "currentSelfDischargingRateValue",
      "kind": "Property",
      "preferredName": "current self discharge rate value",
      "description": "Current self-discharge in % of capacity per unit of time in defined conditions (temperature range) during the use phase."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#stateOfCharge",
      "label": "stateOfCharge",
      "kind": "Property",
      "preferredName": "state of charge (SoC)",
      "description": "Available capacity in a battery expressed as a percentage of remaining capacity.  \n\nDIN DKE Spec 99100 chapter reference: 6.7.2.8 (changed: available energy or charge in a battery expressed as a percentage of rated capacity as declared by the manufacturer, or, when the battery’s state of health is no longer equal to its initial condition, of the maximum energy or charge that can be stored in the battery at the time of charging)"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#stateOfChargeValue",
      "label": "stateOfChargeValue",
      "kind": "Property",
      "preferredName": "state of charge value",
      "description": "Available capacity in a battery expressed as a percentage of remaining capacity."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingRoundTripEnergyEfficiency",
      "label": "remainingRoundTripEnergyEfficiency",
      "kind": "Property",
      "preferredName": "remaining round trip energy efficiency",
      "description": "The battery passport shall include information, where possible, about the remaining round trip energy efficiency as information on the state of health of the battery \n\nThe update frequency of remaining round trip energy efficiency should be aligned with the update frequency of round trip energy efficiency fade and should be provided upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.4"
    },
    {
      "id": "urn:samm:io.admin-shell.idta.batterypass.product_condition:1.0.0#remainingRoundTripEnergyEfficiencyValue",
      "label": "remainingRoundTripEnergyEfficiencyValue",
      "kind": "Property",
      "preferredName": "remaining round trip energy efficiency value",
      "description": "Percentage of energy that can be recovered and used after a full charge and discharge cycle, reflecting the battery's ability to retain and return energy efficiently over time."
    },
