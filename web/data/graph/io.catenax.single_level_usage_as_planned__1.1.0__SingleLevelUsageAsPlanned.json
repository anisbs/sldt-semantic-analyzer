  "nodes": [
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#SingleLevelUsageAsPlanned",
      "label": "SingleLevelUsageAsPlanned",
      "kind": "Aspect",
      "preferredName": "Single Level Usage as Planned",
      "description": "The aspect provides the information in which parent part(s)/product(s) the given item is assembled in. This could be a 1:1 relationship in terms of a e.g. a brake component or 1:n for e.g. coatings. The given item as well as the parent item must refer to an object from as-planned lifecycle phase.\nIf multiple versions of parent parts exist that the child part can be assembled into, all versions of the parent part are included in the usage list."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#catenaXId",
      "label": "catenaXId",
      "kind": "Property",
      "preferredName": "Catena-X Identifier",
      "description": "The Catena-X ID of the given part (e.g. the assembly), valid for the Catena-X dataspace."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#parentParts",
      "label": "parentParts",
      "kind": "Property",
      "preferredName": "Parent Parts",
      "description": "Set of parent parts, in which the given child object is assembled in (one structural level up)."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#parentCatenaXId",
      "label": "parentCatenaXId",
      "kind": "Property",
      "preferredName": "Catena-X Parent ID",
      "description": "The Catena-X ID of the parent object, into which the given child object is assembled in."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#createdOn",
      "label": "createdOn",
      "kind": "Property",
      "preferredName": "Created on",
      "description": "Timestamp when the relation between the parent part and the child part was created."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#quantity",
      "label": "quantity",
      "kind": "Property",
      "preferredName": "Quantity",
      "description": "Quantity of which the child part is assembled into the parent part."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#lastModifiedOn",
      "label": "lastModifiedOn",
      "kind": "Property",
      "preferredName": "Last Modified on ",
      "description": "Timestamp when the assembly relationship between parent part and child part was last modified."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#validityPeriod",
      "label": "validityPeriod",
      "kind": "Property",
      "preferredName": "Validity Period",
      "description": "The period of time during which the parent-child relation is valid. This relates to whether a child part can be built into the parent part at a given time.\nIf no validity period is given the relation is considered valid at any point in time."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#quantityNumber",
      "label": "quantityNumber",
      "kind": "Property",
      "preferredName": "Quantity Number",
      "description": "The number of objects related to the measurement unit"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#measurementUnit",
      "label": "measurementUnit",
      "kind": "Property",
      "preferredName": "Measurement Unit",
      "description": "Unit of measurement for the quantity of objects.\nIf possible, use units from the aspect meta model unit catalog, which is based on the UNECE Recommendation No. 20 \"Codes for Units of Measure used in International Trade\""
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#validFrom",
      "label": "validFrom",
      "kind": "Property",
      "preferredName": "Valid from",
      "description": "Start date of validity period"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#validTo",
      "label": "validTo",
      "kind": "Property",
      "preferredName": "Valid to",
      "description": "End date of validity period"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#CatenaXIdTraitCharacteristic",
      "label": "CatenaXIdTraitCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Catena-X ID Trait Characteristic",
      "description": "Trait to ensure UUID v4 data format"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#SetOfParentPartsCharacteristic",
      "label": "SetOfParentPartsCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Set of Parent Parts",
      "description": "Set of parent parts the given child object is assembled in (one structural level up)."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#Uuidv4Characteristic",
      "label": "Uuidv4Characteristic",
      "kind": "Characteristic",
      "preferredName": "UUID v4",
      "description": "A version 4 UUID is a universally unique identifier that is generated using random 32 hexadecimal characters."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#ValidityPeriodCharacteristic",
      "label": "ValidityPeriodCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Validity Period Characteristic",
      "description": "Characteristic  for a validity period defined by an (optional) start and an (optional) end timestamp."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#NumberOfObjects",
      "label": "NumberOfObjects",
      "kind": "Characteristic",
      "preferredName": "Number of Objects",
      "description": "Quantifiable number of objects in reference to the measurementUnit"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#Uuidv4RegularExpression",
      "label": "Uuidv4RegularExpression",
      "kind": "Characteristic",
      "preferredName": "Catena-X ID Regular Expression",
      "description": "The provided regular expression ensures that the UUID is composed of five groups of characters separated by hyphens, in the form 8-4-4-4-12 for a total of 36 characters (32 hexadecimal characters and 4 hyphens), optionally prefixed by \"urn:uuid:\" to make it an IRI."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#ParentData",
      "label": "ParentData",
      "kind": "Entity",
      "preferredName": "Parent Data",
      "description": "Catena-X ID and meta data of the parent part."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#Quantity",
      "label": "Quantity",
      "kind": "Entity",
      "preferredName": "Quantity",
      "description": "Comprises the number of objects and the unit of measurement for the respective child objects"
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#ValidityPeriodEntity",
      "label": "ValidityPeriodEntity",
      "kind": "Entity",
      "preferredName": "Validity Period Entity",
      "description": "If a validity period only has a start that means that the period is valid from the start date without a (yet) defined enddate and vice versa."
    },
    {
      "id": "urn:bamm:io.catenax.single_level_usage_as_planned:1.1.0#QuantityCharacteristic",
      "label": "QuantityCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Quantity Characteristic",
      "description": "Describes the quantity in which the child part is assembled in the parent object by providing a quantity value and the measurement unit in which the quantity is measured."
    }
  ],
