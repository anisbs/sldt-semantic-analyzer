    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#Quantity",
      "label": "Quantity",
      "kind": "Characteristic",
      "preferredName": "Quantity",
      "description": "Quantities of weekly demands."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#DemandSeriesSet",
