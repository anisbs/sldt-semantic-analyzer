      "preferredName": "Business Partner Number Legal Entity",
      "description": "BPNL represents the legal entity of an organization participating in Catena-X."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#MaterialNumber",
      "label": "MaterialNumber",
