  "nodes": [
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#WeekBasedMaterialDemand",
      "label": "WeekBasedMaterialDemand",
      "kind": "Aspect",
      "preferredName": "Week-Based Material Demand",
      "description": "The requirements of a customer towards a specific supplier for a specific material. Each material demand is unique by its Customer, Supplier and Material Number."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#materialDemandId",
      "label": "materialDemandId",
      "kind": "Property",
      "preferredName": "Material Demand ID",
      "description": "The Material Demand ID uniquely identifies the material demand within the business relationship between a customer and its supplier."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demandSeries",
      "label": "demandSeries",
      "kind": "Property",
      "preferredName": "Demand Series",
      "description": "The weekly demands for a dedicated material in a given time period, distinguished by their demand location and demand category."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#customer",
      "label": "customer",
      "kind": "Property",
      "preferredName": "Customer",
      "description": "The Business Partner Number (BPNL) of the party requesting materials from a supplier."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#supplier",
      "label": "supplier",
      "kind": "Property",
      "preferredName": "Supplier",
      "description": "The Business Partner Number (BPNL) of the party providing materials to a customer."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#unitOfMeasure",
      "label": "unitOfMeasure",
      "kind": "Property",
      "preferredName": "Unit of Measure",
      "description": "Unit of measurement for demand quantities."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#materialNumberCustomer",
      "label": "materialNumberCustomer",
      "kind": "Property",
      "preferredName": "Customer Material Number",
      "description": "Material identifier as assigned by customer. This material number identifies the material (as planned) in customer's database. Must be unique for each Material Demand in the customer-supplier relationship."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#materialNumberSupplier",
      "label": "materialNumberSupplier",
      "kind": "Property",
      "preferredName": "Supplier Material Number",
      "description": "Material identifier as assigned by supplier. This material number identifies the material (as planned) in supplier's database."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#materialDescriptionCustomer",
      "label": "materialDescriptionCustomer",
      "kind": "Property",
      "preferredName": "Customer Material Description",
      "description": "Description of the material."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#changedAt",
      "label": "changedAt",
      "kind": "Property",
      "preferredName": "Changed At",
      "description": "Point in time when the content (any property according to the data model) of the material demand was changed, at the customer, either by a human user or an automated process."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#expectedSupplierLocation",
      "label": "expectedSupplierLocation",
      "kind": "Property",
      "preferredName": "Expected Supplier Location",
      "description": "The BPNS number of the site from where the customer expects the supplier to fulfill the demands of the demand series. The value is used for informational purposes only and is therefore not binding for the supplier."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#customerLocation",
      "label": "customerLocation",
      "kind": "Property",
      "preferredName": "Customer Location",
      "description": "The BPNS number of the site at which the customer needs the specified material for this demand series."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demandCategory",
      "label": "demandCategory",
      "kind": "Property",
      "preferredName": "Demand Category",
      "description": "Type of demand for this demand series."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demands",
      "label": "demands",
      "kind": "Property",
      "preferredName": "Demands",
      "description": "A time series with week-based granularity along a given time period to describe the demand values for this demand series."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demandCategoryCode",
      "label": "demandCategoryCode",
      "kind": "Property",
      "preferredName": "Demand Category Code",
      "description": "The code identifying a demand category."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demandCategoryName",
      "label": "demandCategoryName",
      "kind": "Property",
      "preferredName": "Demand Category Name",
      "description": "The name describing a demand category."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#calendarWeek",
      "label": "calendarWeek",
      "kind": "Property",
      "preferredName": "Calendar Week",
      "description": "ISO Calendar Week of the given time series entry. Must be given as date of the Monday in the week."
    },
    {
      "id": "urn:bamm:io.catenax.week_based_material_demand:1.0.1#demand",
      "label": "demand",
      "kind": "Property",
      "preferredName": "Demand",
      "description": "Quantity of materials required in the specified calendar week."
    },
    {
