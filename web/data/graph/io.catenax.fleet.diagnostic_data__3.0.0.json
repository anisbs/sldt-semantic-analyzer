    {
      "id": "urn:samm:io.catenax.fleet.diagnostic_data:3.0.0#fullName",
      "label": "fullName",
      "kind": "Property",
      "preferredName": "DTC Full Name",
      "description": "A human-readable name that is the result of the translation of DTC hex code. There is a 1:1 relationship between DTC hex code and DTC full name. DTC full name must include the fault byte added after the minus. DTC full name is unique: That means that at one occurrence timestamp and the same vehicle and the same ECU only one DTC full name can be set."
    },
    {
      "id": "urn:samm:io.catenax.fleet.diagnostic_data:3.0.0#fullDescription",
      "label": "fullDescription",
      "kind": "Property",
      "preferredName": "DTC Description",
      "description": "Description of this DTC. If description name consists of main DTC  and failure byte, than both description strings are concatenated using a \"-\" as separator."
    },
