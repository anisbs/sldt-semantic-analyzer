    {
      "id": "urn:samm:io.catenax.material_accounting:1.0.0#secondaryMaterial",
      "label": "secondaryMaterial",
      "kind": "Property",
      "preferredName": "secondary material",
      "description": "Material share from all materials obtained from waste, by-products and production residues sources. In the material cycle diagrams, this corresponds to the material flows PrC, PoC and ReU-M.  This includes substances and mixtures of substances that are intended for the manufacture of products. This can include both secondary raw materials and more highly processed substances and mixtures of substances. Secondary material can be used as a substitute for primary material in processes."
    },
    {
      "id": "urn:samm:io.catenax.material_accounting:1.0.0#primaryMaterial",
      "label": "primaryMaterial",
      "kind": "Property",
      "preferredName": "primary material",
      "description": "Material share from Substances and mixtures of substances intended for the manufacture of products and used for the first time in a production process. "
    },
