  "nodes": [
    {
      "id": "urn:samm:io.catenax.material_accounting:1.0.0#RecyclingInformation",
      "label": "RecyclingInformation",
      "kind": "Aspect",
      "preferredName": "recycling information",
      "description": "The RecyclingInformation aspect model defines a standardized and interoperable representation of recycling-related material shares, including material origin, reutilization, pre- and post-consumer shares, and primary and secondary material sources, in a consistent and machine-readable manner."
    },
    {
      "id": "urn:samm:io.catenax.material_accounting:1.0.0#reutilizationMaterialShare",
      "label": "reutilizationMaterialShare",
      "kind": "Property",
      "preferredName": "reutilization material share",
      "description": "Material share from reutilization of materials such as rework, regrind, or scrap materials generated within the process and capable of being reused within the same process that generated it."
    },
    {
      "id": "urn:samm:io.catenax.material_accounting:1.0.0#origin",
      "label": "origin",
      "kind": "Property",
      "preferredName": "origin",
      "description": "Information on material origin."
    },
    {
