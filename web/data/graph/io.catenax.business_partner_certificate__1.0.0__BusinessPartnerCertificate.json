    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#BusinessPartnerCertificate",
      "label": "BusinessPartnerCertificate",
      "kind": "Aspect",
      "preferredName": "Business Partner certificate",
      "description": "A business partner certifcate describes a certificate (eg ISO9001, IATF-16949) via a certifcate document  of a Catena-X business partner"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#businessPartnerNumber",
      "label": "businessPartnerNumber",
      "kind": "Property",
      "preferredName": "Business Partner number",
      "description": "The BPN of the certified legal entity "
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#type",
      "label": "type",
      "kind": "Property",
      "preferredName": "Certificate type",
      "description": "Type of the certificate as defined on the document like IS09001, IATF 16949 or other"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#certificateType",
      "label": "certificateType",
      "kind": "Property",
      "preferredName": "Certificate type",
      "description": "Type of the certificate as defined on the document,valid types are registered at BPN metadatacontroller"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#certificateVersion",
      "label": "certificateVersion",
      "kind": "Property",
      "preferredName": "Certificate version",
      "description": "Version of the certificate as defined on the document, usually the specific version of a certification standard"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#registrationNumber",
      "label": "registrationNumber",
      "kind": "Property",
      "preferredName": "Certificate registration number",
      "description": "Registration number of the certificate as defined on the certificate"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#areaOfApplication",
      "label": "areaOfApplication",
      "kind": "Property",
      "preferredName": "area of application",
      "description": "Details on which areas / application types a certificate is valid for a company"
    },
    {
      "id": "urn:samm:io.catenax.business_partner_certificate:1.0.0#enclosedSites",
