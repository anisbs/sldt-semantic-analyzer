    {
      "id": "urn:samm:io.admin-shell.idta.generic.technical_data:1.2.0#manufacturerProductDesignation",
      "label": "manufacturerProductDesignation",
      "kind": "Property",
      "preferredName": "Produktbezeichnung",
      "description": "Short description of the product (short text), third or lowest level of a 3 level manufacturer specific product hierarchy."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.generic.technical_data:1.2.0#manufacturerArticleNumber",
      "label": "manufacturerArticleNumber",
      "kind": "Property",
