    {
      "id": "urn:samm:io.admin-shell.idta.generic.technical_data:1.2.0#productClassificationSystem",
      "label": "productClassificationSystem",
      "kind": "Property",
      "preferredName": "product classification system",
      "description": "Common name of the classification system.\nNote: Examples for common names for classification systems are \"ECLASS\" or \"IEC CDD\"."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.generic.technical_data:1.2.0#classificationSystemVersion",
      "label": "classificationSystemVersion",
      "kind": "Property",
      "preferredName": "classification system version",
      "description": "Common version identifier of the used classification system, in order to distinguish different version of the property dictionary.\nNote: Casing is to be ignored."
    },
    {
      "id": "urn:samm:io.admin-shell.idta.generic.technical_data:1.2.0#productClassId",
      "label": "productClassId",
      "kind": "Property",
      "preferredName": "product class ID",
      "description": "Class of the associated product or industrial equipment in the classification system. According to the notation of the system.\nNote: Ideally, the Property/valueId is used to reference the IRI/ IRDI of the product class."
    },
