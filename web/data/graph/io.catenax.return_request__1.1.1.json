    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#ReturnRequest",
      "label": "ReturnRequest",
      "kind": "Aspect",
      "preferredName": "return request",
      "description": "Aspect to indicate if there is a return request for a product."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#needsReturn",
      "label": "needsReturn",
      "kind": "Property",
      "preferredName": "needs return",
      "description": "Describes the fact whether a vehicle, assembly or part needs to be returned to requestor."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#returnConditions",
      "label": "returnConditions",
      "kind": "Property",
      "preferredName": "return conditions",
      "description": "Describes WHY a vehicle, assembly or part needs to be returned to the requestor and under which conditions."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#requestDate",
      "label": "requestDate",
      "kind": "Property",
      "preferredName": "request date",
      "description": "Describes date when the return request was placed in GMT timezone."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#latestReturnDate",
      "label": "latestReturnDate",
      "kind": "Property",
      "preferredName": "latest return date",
      "description": "Describes until when the return request is valid in GMT timezone."
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#productConditions",
      "label": "productConditions",
      "kind": "Property",
      "preferredName": "product conditions",
      "description": "textual description of the product conditions"
    },
    {
      "id": "urn:bamm:io.catenax.return_request:1.1.1#title",
