  "nodes": [
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#RecyclingStrategyCertificate",
      "label": "RecyclingStrategyCertificate",
      "kind": "Aspect",
      "preferredName": "Recycling strategy certificate",
      "description": "The certificate marks the point in time at which an asset irrevocably enters a new life. The eol (end of life) phase is completed and a new product life cycle is started."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#recyclingStrategyCertificateProperty",
      "label": "recyclingStrategyCertificateProperty",
      "kind": "Property",
      "preferredName": "Recycling strategy certificate property",
      "description": "This property represents the moment when something stops being used and officially begins a new life. It marks the end of its old life and the start of a new one."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#supplier",
      "label": "supplier",
      "kind": "Property",
      "preferredName": "Supplier",
      "description": "BPN of the business partner who creates this certificate"
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#issueDate",
      "label": "issueDate",
      "kind": "Property",
      "preferredName": "Issue date",
      "description": "This is the date when the certificate was issued."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#catenaXIdPreviousLife",
      "label": "catenaXIdPreviousLife",
      "kind": "Property",
      "preferredName": "Catena X ID previous life",
      "description": "Twin identification previous life"
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#catenaXId",
      "label": "catenaXId",
      "kind": "Property",
      "preferredName": "Catena-X Identifier",
      "description": "The Catena-X ID of the given part (e.g. the assembly), valid for the Catena-X dataspace."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#articleNumber",
      "label": "articleNumber",
      "kind": "Property",
      "preferredName": "Article Number",
      "description": "Unique identification assigned by the authorized company for internal referencing"
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#revocationDate",
      "label": "revocationDate",
      "kind": "Property",
      "preferredName": "Revocation Date",
      "description": "The date when the certificate is revoked by the issuer. This only happens in exceptional cases when an asset has been marked as reused by error or any other error is made in the issuance of the certificate. Certificates may be revoked up to 7 working days after they have been issued."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#van",
      "label": "van",
      "kind": "Property",
      "preferredName": "VAN",
      "description": "Vehicle Anonymized Number of vehicle of which this component has been dismantled."
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#originalEquipmentNumber",
      "label": "originalEquipmentNumber",
      "kind": "Property",
      "preferredName": "Original Equipment Number",
      "description": "Original Equipment Number"
    },
    {
      "id": "urn:samm:io.catenax.shared.recycling_strategy_certificate:3.0.0#vehicleCatenaXId",
      "label": "vehicleCatenaXId",
      "kind": "Property",
      "preferredName": "Vehicle Catena X ID",
      "description": "Catena X ID of the Vehicle from which this component has been dismantled."
    },
    {
