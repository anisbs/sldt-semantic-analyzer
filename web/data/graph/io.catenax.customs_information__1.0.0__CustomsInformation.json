  "nodes": [
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#CustomsInformation",
      "label": "CustomsInformation",
      "kind": "Aspect",
      "preferredName": "Customs Information",
      "description": "To carry out a preference calculation, customs-specific master data is required for all installed parts within a product. For this purpose, the manufacturer of the product requests this information from the relevant suppliers for all purchased parts (part numbers)and uses it for the preference calculation.\n\nThe exchange takes place peer-to-peer from one value-added participant across the two tier levels."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#customsInformation",
      "label": "customsInformation",
      "kind": "Property",
      "preferredName": "Customs Information",
      "description": "CustomsInformation contains all customs-related information for a long-term supplier's declaration for a part. Long-term supplier's declarations (LLE)are one-off declarations that are valid for deliveries over a longer period of time, provided that the delivered goods are expected to have the same origin status."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#catenaXId",
      "label": "catenaXId",
      "kind": "Property",
      "preferredName": "Catena-X Identifier",
      "description": "The fully anonymous Catena-X ID of the corresponding part, valid for the Catena-X dataspace."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#originInformation",
      "label": "originInformation",
      "kind": "Property",
      "preferredName": "Origin Information",
      "description": "OriginInformation contains all the information required to determine that the part is eligible for preferential treatment, i.e. the determination of preferential origin."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#confirmationDate",
      "label": "confirmationDate",
      "kind": "Property",
      "preferredName": "Confirmation Date",
      "description": "Confirmation Date is the date of issue of a long-term supplier's declaration."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#validFrom",
      "label": "validFrom",
      "kind": "Property",
      "preferredName": "Valid From",
      "description": "Valid From is the date from which a long-term supplier declaration is valid. This date can be in the future."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#type",
      "label": "type",
      "kind": "Property",
      "preferredName": "Type",
      "description": "Type is the reason for submitting a long-term supplier's declaration. This may be due to a recurring annual enquiry by the customer or at the start of a supply relationship."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#status",
      "label": "status",
      "kind": "Property",
      "preferredName": "Status",
      "description": "Status represents the stage of a long-term supplier's declaration. Committed indicates to the data recipient that all data has been provided correctly."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#tradeRelation",
      "label": "tradeRelation",
      "kind": "Property",
      "preferredName": "Trade Relation",
      "description": "The trade relation (preferential agreement)for which origin information has been provided."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#commercialCountryOfOrigin",
      "label": "commercialCountryOfOrigin",
      "kind": "Property",
      "preferredName": "Commercial Country Of Origin",
      "description": "The term \"Commercial Country Of Origin\" specifically refers to the country where the goods were originally produced, manufactured or significantly transformed"
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#federalState",
      "label": "federalState",
      "kind": "Property",
      "preferredName": "Federal State",
      "description": "German federal state in which the part was manufactured."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#preferredStatus",
      "label": "preferredStatus",
      "kind": "Property",
      "preferredName": "Preferred Status",
      "description": "This is the preference status of the part."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#tracedWorth",
      "label": "tracedWorth",
      "kind": "Property",
      "preferredName": "Traced Worth",
      "description": "Material value of the part in a currency unit."
    },
    {
      "id": "urn:samm:io.catenax.customs_information:1.0.0#contactInformation",
