      "id": "urn:bamm:io.catenax.manufacturing_capability:1.0.0#ManufacturingCapability",
      "label": "ManufacturingCapability",
      "kind": "Aspect",
      "preferredName": "Manufacturing Capability Aspect Model",
      "description": "An aspect model representing manufacturing capabilities, based on the concepts for products, processes, resources and capabilities, as well as their relations to each other."
    },
    {
      "id": "urn:bamm:io.catenax.manufacturing_capability:1.0.0#processSet",
      "label": "processSet",
      "kind": "Property",
      "preferredName": "Process Set",
      "description": "Set of production-relevant activities at any level of granularity that might affect materials and is performed by resources."
    },
    {
      "id": "urn:bamm:io.catenax.manufacturing_capability:1.0.0#resourceSet",
      "label": "resourceSet",
      "kind": "Property",
      "preferredName": "Resource Set",
      "description": "Set of entities capable of performing functions specified as capabilities."
    },
