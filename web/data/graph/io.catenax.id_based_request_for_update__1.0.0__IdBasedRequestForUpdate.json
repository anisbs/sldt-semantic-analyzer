  "nodes": [
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#IdBasedRequestForUpdate",
      "label": "IdBasedRequestForUpdate",
      "kind": "Aspect",
      "preferredName": "ID Based Request For Update",
      "description": "The requirements for a request for update from another Catena-X Partner of a specific entity.\nIf within the payload, no specific object type is defined (Payload empty), than an update of all objects within the sender reciever relation is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#weekBasedMaterialDemand",
      "label": "weekBasedMaterialDemand",
      "kind": "Property",
      "preferredName": "Week Based Material Demand List",
      "description": "Material demands the supplier requests an update for.\nIf within the array, no specific ID (array empty), than an update of all IDs is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#weekBasedCapacityGroup",
      "label": "weekBasedCapacityGroup",
      "kind": "Property",
      "preferredName": "Week Based Capacity Group List",
      "description": "Capacity groups the customer requests an update for.\nIf within the array, no specific ID (array empty), than an update of all IDs is requested)."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#materialDemandId",
      "label": "materialDemandId",
      "kind": "Property",
      "preferredName": "Material Demand ID",
      "description": "The Material Demand ID uniquely identifies the material demand the supplier requests an update for within the business relationship between the customer and its supplier."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#changedAt",
      "label": "changedAt",
      "kind": "Property",
      "preferredName": "Changed At",
      "description": "Point in time of the last update known to the requesting business partner. If the requested entity has been changed more recently, the requested party should resend the data. If the changedAt property is not given, the latest entity should be send without precondition."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#capacityGroupId",
      "label": "capacityGroupId",
      "kind": "Property",
      "preferredName": "Capacity Group ID",
      "description": "The Capacity Group ID uniquely identifies the capacity group the supplier requests an update for within the business relationship between the supplier and its customer."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#WeekBasedMaterialDemandCharacteristic",
      "label": "WeekBasedMaterialDemandCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Week Based Material Demand Characteristic",
      "description": "A list of material demand UUIDs without duplicates an update is requested for."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#WeekBasedCapacityGroupCharacteristic",
      "label": "WeekBasedCapacityGroupCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Week Based Capacity Group Characteristic",
      "description": "A list of capacity group UUIDs without duplicates an update is requested for."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#WeekBasedMaterialDemandEntity",
      "label": "WeekBasedMaterialDemandEntity",
      "kind": "Entity",
      "preferredName": "Week Based Material Demand Entity",
      "description": "Encapsulates the information that is necessary for an update request."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#WeekBasedCapacityGroupEntity",
      "label": "WeekBasedCapacityGroupEntity",
      "kind": "Entity",
      "preferredName": "Week Based Capacity Group Entity",
      "description": "Encapsulates the information that is necessary for an update request."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#UUIDv4IdTrait",
      "label": "UUIDv4IdTrait",
      "kind": "Characteristic",
      "preferredName": "UUIDv4 Trait",
      "description": "Trait to ensure data format for UUIDv4."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#Timestamp",
      "label": "Timestamp",
      "kind": "Characteristic",
      "preferredName": "Timestamp",
      "description": "Describes a Property which contains the date and time with an optional timezone."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#UUIDv4",
      "label": "UUIDv4",
      "kind": "Characteristic",
      "preferredName": "UUIDv4",
      "description": "A version 4 UUID is a universally unique identifier that is generated using random 32 hexadecimal characters."
    },
    {
      "id": "urn:samm:io.catenax.id_based_request_for_update:1.0.0#UUIDv4RegularExpression",
      "label": "UUIDv4RegularExpression",
      "kind": "Characteristic",
      "preferredName": "UUIDv4 Regular Expression",
      "description": "The provided regular expression ensures that the UUID is composed of five groups of characters separated by hyphens, in the form 8-4-4-4-12 for a total of 36 characters (32 hexadecimal characters and 4 hyphens)."
    }
  ],
