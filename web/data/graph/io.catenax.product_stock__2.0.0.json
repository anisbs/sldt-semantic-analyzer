    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#Position",
      "label": "Position",
      "kind": "Entity",
      "preferredName": "Position",
      "description": "The Position can be located at several stocks. A position may be anonymous or may reference an position within an order."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#OrderPositionReference",
      "label": "OrderPositionReference",
      "kind": "Entity",
      "preferredName": "Reference to Order Position",
      "description": "Encapsulates the references to identify a position within an order."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#AllocatedStock",
      "label": "AllocatedStock",
      "kind": "Entity",
      "preferredName": "Stock Allocated to Customer",
      "description": "This is the quantity of already produced goods at a given location that has not yet been shipped. The allocated stock is the stock available for the customer and may refer to a given position (see OrderPositionReference). Quantities of Materials belonging to this stock are not available for other positions or customers. This stock consists only of the good parts."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#Quantity",
      "label": "Quantity",
      "kind": "Entity",
      "preferredName": "Quantity",
      "description": "Comprises the number of objects and the unit of measurement for the respective child objects"
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#LocationId",
      "label": "LocationId",
      "kind": "Entity",
      "preferredName": "Location ID",
      "description": "A location can be described by different kinds of identifiers. Within Catena-X, a location can either be described by a BPNS or BPNA."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#Uuidv4RegularExpression",
      "label": "Uuidv4RegularExpression",
      "kind": "Characteristic",
      "preferredName": "Catena-X ID Regular Expression",
      "description": "The provided regular expression ensures that the UUID is composed of five groups of characters separated by hyphens, in the form 8-4-4-4-12 for a total of 36 characters (32 hexadecimal characters and 4 hyphens), optionally prefixed by \"urn:uuid:\" to make it an IRI."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#QuantityCharacteristic",
      "label": "QuantityCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Quantity Characteristic",
      "description": "Describes the quantity in which the child part is assembled in the given parent object by providing a quantity value and the measurement unit in which the quantity is measured."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#LocationIdTypeEnum",
