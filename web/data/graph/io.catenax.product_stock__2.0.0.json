        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#SupplierStockLocationIDCharacteristic",
      "label": "SupplierStockLocationIDCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Location ID Characteristic of Supplier's Stock",
      "description": "This is the location where the stock is located."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#NumberofObjects",
      "label": "NumberofObjects",
      "kind": "Characteristic",
      "preferredName": "Number of Objects",
