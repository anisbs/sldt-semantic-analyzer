  "nodes": [
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#ProductStock",
      "label": "ProductStock",
      "kind": "Aspect",
      "preferredName": "Stock of Products of a Supplier",
      "description": "This aspect represents the latest quantities of a supplier's products that are on stock. The stock represent the build-to-order (BTO) stocks already available for the customer."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#positions",
      "label": "positions",
      "kind": "Property",
      "preferredName": "Positions",
      "description": "The positions refer to positions within an order that refer to the given product (see materialNumberSupplier, materialNumberCustomer and materialNumberDataSpace) for which the stocks are transferred. The positions are differentiated by the orderPositionReference."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#materialNumberCustomer",
      "label": "materialNumberCustomer",
      "kind": "Property",
      "preferredName": "Customer Material Number",
      "description": "Material identifier as assigned by customer. This material number identifies the material (as planned) in customer's database. For standard parts (e.g. screws) for which a customer does not have an own number, the materialNumberSupplier should be set in this field, too."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#materialNumberCatenaX",
      "label": "materialNumberCatenaX",
      "kind": "Property",
      "preferredName": "Material UUID Used in Catena-X",
      "description": "Material identifier used uniquely within Catena-X to identify the Material (e.g. PartAsPlanned)."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#materialNumberSupplier",
      "label": "materialNumberSupplier",
      "kind": "Property",
      "preferredName": "Supplier Material Number",
      "description": "Material identifier as assigned by supplier. This material number identifies the material (as planned) in supplier's database."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#orderPositionReference",
      "label": "orderPositionReference",
      "kind": "Property",
      "preferredName": "Order Position Reference",
      "description": "The order position reference contains information to identify a position within an order."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#lastUpdatedOnDateTime",
      "label": "lastUpdatedOnDateTime",
      "kind": "Property",
      "preferredName": "Lasted Updated on Date",
      "description": "Date and time at which the position has been updated by the supplier's systems. Date and time are set according to a timezone."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#allocatedStocks",
      "label": "allocatedStocks",
      "kind": "Property",
      "preferredName": "Allocated Stocks",
      "description": "Stocks already allocated to the customer. There is one AllocatedStock per supplierStockLocation."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#supplierOrderId",
      "label": "supplierOrderId",
      "kind": "Property",
      "preferredName": "Supplier Order ID",
      "description": "This is the order number on the supplier side that is given by e.g., the supplier's enterprise resource planning system."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#customerOrderId",
      "label": "customerOrderId",
      "kind": "Property",
      "preferredName": "Customer Order ID",
      "description": "This is the order number on the customer side that can be given by e.g., the customer's enterprise resource planning system."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#customerOrderPositionId",
      "label": "customerOrderPositionId",
      "kind": "Property",
      "preferredName": "Customer Order Position ID",
      "description": "This is an identifier for the position of an order defined by the customer. It's not a technical identifier, such as an UUID. This identifier is used within the business context when talking about the position."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#quantityOnAllocatedStock",
      "label": "quantityOnAllocatedStock",
      "kind": "Property",
      "preferredName": "Quantity on Allocated Stock",
      "description": "This is the quantity of the material within the position that is already ready to be delivered."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#supplierStockLocationId",
      "label": "supplierStockLocationId",
      "kind": "Property",
      "preferredName": "Location ID of Supplier's Stock",
      "description": "One stock has always one location. The location is identified using BPNs. The location can be identified differently depending on the partner."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#quantityNumber",
      "label": "quantityNumber",
      "kind": "Property",
      "preferredName": "Quantity Number",
      "description": "The number of objects related to the measurement unit"
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#measurementUnit",
      "label": "measurementUnit",
      "kind": "Property",
      "preferredName": "Measurement Unit",
      "description": "Unit of measurement for the quantity of objects.\nIf possible, use units from the aspect meta model unit catalog, which is based on the UNECE Recommendation No. 20 \"Codes for Units of Measure used in International Trade\".",
      "external_refs": [
        {
          "predicate": "characteristic",
          "target_local": "UnitReference",
          "target_model": "org.eclipse.esmf.samm:characteristic@2.1.0",
          "target_source": "unknown"
        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#locationIdType",
      "label": "locationIdType",
      "kind": "Property",
      "preferredName": "Type of Location ID",
      "description": "Type of the location's ID."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#locationId",
      "label": "locationId",
      "kind": "Property",
      "preferredName": "Location ID",
      "description": "The actual ID reflecting the type (locationIdType) of the location."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#PositionsCollection",
      "label": "PositionsCollection",
      "kind": "Characteristic",
      "preferredName": "Positions Collection",
      "description": "If any stock is available, then there is at least one position. If the supplier does differentiate the stock according to the order positions (an OrderPositionReference is set), then multiple positions can be given. There could also be only one position without an OrderPositionReference indicating an anonymous stock which is allocated to the customer."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#AllocatedStockCollection",
      "label": "AllocatedStockCollection",
      "kind": "Characteristic",
      "preferredName": "Allocated Stock Collection",
      "description": "Collection of AllocatedStocks that may relate to different supplierStockLocations."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#MaterialNumber",
      "label": "MaterialNumber",
      "kind": "Characteristic",
      "preferredName": "Material Number",
      "description": "The material number is a multi-character string, usually assigned by an ERP system.",
      "external_refs": [
        {
          "predicate": "dataType",
          "target_local": "string",
          "target_model": "",
          "target_source": "unknown"
        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#Uuidv4Characteristic",
      "label": "Uuidv4Characteristic",
      "kind": "Characteristic",
      "preferredName": "UUID v4",
      "description": "A version 4 UUID is a universally unique identifier that is generated using random 32 hexadecimal characters.",
      "external_refs": [
        {
          "predicate": "dataType",
          "target_local": "string",
          "target_model": "",
          "target_source": "unknown"
        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#OrderPositionReferenceCharacteristic",
      "label": "OrderPositionReferenceCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Order Position Reference Characteristic",
      "description": "The order position reference includes reference numbers for the order and the ID. As these information are meant for the customer, the customer reference numbers are mandatory."
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#DateTimeStamp",
      "label": "DateTimeStamp",
      "kind": "Characteristic",
      "preferredName": "Date Time Stamp Characteristic",
      "description": "The Date with the the timezone of the involved site.",
      "external_refs": [
        {
          "predicate": "dataType",
          "target_local": "date",
          "target_model": "",
          "target_source": "unknown"
        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#OrderIdCharacteristic",
      "label": "OrderIdCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Order ID Characteristic",
      "description": "This is a proprietary order ID, generated by either the supplier side or customer side.",
      "external_refs": [
        {
          "predicate": "dataType",
          "target_local": "string",
          "target_model": "",
          "target_source": "unknown"
        }
      ]
    },
    {
      "id": "urn:samm:io.catenax.product_stock:2.0.0#OrderPositionIdCharacteristic",
      "label": "OrderPositionIdCharacteristic",
      "kind": "Characteristic",
      "preferredName": "Position ID within Order",
      "description": "The position ID is unique for an order and used within business context to refer to a position.",
      "external_refs": [
        {
          "predicate": "dataType",
