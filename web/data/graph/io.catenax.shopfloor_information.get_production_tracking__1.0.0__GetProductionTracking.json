      "description": "Internal customer Identification"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#capabilityId",
      "label": "capabilityId",
      "kind": "Property",
      "preferredName": "Capability Identifier",
      "description": "Identifier of a capability that is required in case of a capability based request"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#billOfMaterialId",
      "label": "billOfMaterialId",
      "kind": "Property",
      "preferredName": "Bill of Material Identifier",
      "description": "Identifier for a bill of material, which is known by both partners"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#processStepId",
      "label": "processStepId",
      "kind": "Property",
      "preferredName": "Process Step Identifier",
      "description": "Id of a process Step, specified within an instance of a bill of process data model that is known to both partners"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#processParameterList",
      "label": "processParameterList",
      "kind": "Property",
      "preferredName": "Process Parameter List",
      "description": "List of requested Process parameter"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#partInstanceLevel",
      "label": "partInstanceLevel",
      "kind": "Property",
      "preferredName": "Part Instance Level",
      "description": "Specifies for the case of a  capability based request, whether the parts are identified with a serial number or with a bill of material "
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#partInstanceId",
      "label": "partInstanceId",
      "kind": "Property",
      "preferredName": "Part Instance Identifier",
      "description": "Identifies an instance of a part in case that the partInstanceLevel property has the value partInstanceId "
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#billOfMaterialElementId",
      "label": "billOfMaterialElementId",
      "kind": "Property",
      "preferredName": "Bill of Material Element Identifier",
      "description": "Identifier of an element that is part of the bill of material, referenced by the bill of material Id "
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#processParameterName",
      "label": "processParameterName",
