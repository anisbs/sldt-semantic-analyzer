      "label": "GetProductionTracking",
      "kind": "Aspect",
      "preferredName": "Get Production Tracking",
      "description": "Aspect to request product specific data from modular production"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#request",
      "label": "request",
      "kind": "Property",
      "preferredName": "Request",
      "description": "Contains the data for the production tracking request"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#stepIdentifierList",
      "label": "stepIdentifierList",
      "kind": "Property",
      "preferredName": "Step Identifier List",
      "description": "List of manufacturing steps from which a set of parameter is requested. The manufacturing steps are either determined by a capability or a process step identifier"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#processReferenceType",
      "label": "processReferenceType",
      "kind": "Property",
      "preferredName": "Process Reference Type",
      "description": "Value of an enumeration that determines whether the request is based on concrete process steps (Bill of process) or capabilities"
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#billOfProcessId",
      "label": "billOfProcessId",
      "kind": "Property",
      "preferredName": "Bill of Process Identifier",
      "description": "Id to identify an instance of the bill of process data model "
    },
    {
      "id": "urn:samm:io.catenax.shopfloor_information.get_production_tracking:1.0.0#customerId",
      "label": "customerId",
      "kind": "Property",
