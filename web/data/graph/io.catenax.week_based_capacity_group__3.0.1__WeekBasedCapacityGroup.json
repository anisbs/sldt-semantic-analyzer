  "nodes": [
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#WeekBasedCapacityGroup",
      "label": "WeekBasedCapacityGroup",
      "kind": "Aspect",
      "preferredName": "Week-Based Capacity Group",
      "description": "An entity made up of the weekly actual and maximum capacities for a specific customer in a given time period. A capacity group is used to compare demand and capacity data for one or several similar bundled materials in a defined unit of measure."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#capacityGroupId",
      "label": "capacityGroupId",
      "kind": "Property",
      "preferredName": "Capacity Group ID",
      "description": "The Capacity Group ID uniquely identifies the capacity group within the business relationship between a supplier and its customer."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#name",
      "label": "name",
      "kind": "Property",
      "preferredName": "Capacity Group Name",
      "description": "Name of the capacity group."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#supplierLocations",
      "label": "supplierLocations",
      "kind": "Property",
      "preferredName": "Supplier Locations",
      "description": "Set of BPNS indicating the supplier sites that will be fulfilling the demands associated with this capacity group."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#customer",
      "label": "customer",
      "kind": "Property",
      "preferredName": "Customer",
      "description": "The Business Partner Number (BPNL) of the party requesting materials from a supplier."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#supplier",
      "label": "supplier",
      "kind": "Property",
      "preferredName": "Supplier",
      "description": "The Business Partner Number (BPNL) of the party providing materials to a customer."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#unitOfMeasure",
      "label": "unitOfMeasure",
      "kind": "Property",
      "preferredName": "Unit of Measure",
      "description": "Unit of measurement for capacity quantities."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#linkedDemandSeries",
      "label": "linkedDemandSeries",
      "kind": "Property",
      "preferredName": "Linked Demand Series",
      "description": "Set of demand series assigned to this capacity group."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#capacities",
      "label": "capacities",
      "kind": "Property",
      "preferredName": "Capacities",
      "description": "A time series with week-based granularity along a given time period containing the capacity values."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#changedAt",
      "label": "changedAt",
      "kind": "Property",
      "preferredName": "Changed At",
      "description": "Point in time when the content (any property according to the data model) of the capacity group was changed, at the supplier, either by a human user or an automated process."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#linkedCapacityGroups",
      "label": "linkedCapacityGroups",
      "kind": "Property",
      "preferredName": "Linked Capacity Groups",
      "description": "A set of capacity groups linked to this capacity group. This set contains all children capacity groups of the current capacity group in an unidirectional path."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#unitOfMeasureIsOmitted",
      "label": "unitOfMeasureIsOmitted",
      "kind": "Property",
      "preferredName": "Unit Of Measure Is Omitted",
      "description": "Explicit indicator of whether the unit of measure is left out of the payload intentionally. If \"true\" it means the sending application sends demand values without unit of measure intentionally and the unit of measure MUST NOT be contained in the payload. If \"false\" a unit of measure MUST be supplied."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#demandVolatilityParameters",
      "label": "demandVolatilityParameters",
      "kind": "Property",
      "preferredName": "Demand Volatility Parameters",
      "description": "The parameters to calibrate the measuring of demand volatility."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#capacityGroupIsInactive",
      "label": "capacityGroupIsInactive",
      "kind": "Property",
      "preferredName": "Capacity Group Is Inactive",
      "description": "Indicates that this capacity group is currently not in use/maintained by the supplier."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#materialNumberCustomer",
      "label": "materialNumberCustomer",
      "kind": "Property",
      "preferredName": "Customer Material Number",
      "description": "Material identifier as assigned by customer. This material number identifies the material (as planned) in the customer's database."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#materialNumberSupplier",
      "label": "materialNumberSupplier",
      "kind": "Property",
      "preferredName": "Supplier Material Number",
      "description": "Material identifier as assigned by supplier. This material number identifies the material (as planned) in the supplier's database. Used as informational field only, not for assigning demand series to capacity groups."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#customerLocation",
      "label": "customerLocation",
      "kind": "Property",
      "preferredName": "Customer Location",
      "description": "The BPNS number of the site at which the customer needs the specified material for the referenced demand series."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#demandCategory",
      "label": "demandCategory",
      "kind": "Property",
      "preferredName": "Demand Category",
      "description": "Type of demand of the referenced demand series."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#loadFactor",
      "label": "loadFactor",
      "kind": "Property",
      "preferredName": "Load Factor",
      "description": "If existent, the load factor indicates that this material of the material demand collection takes a factor more or less intensity to produce."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#pointInTime",
      "label": "pointInTime",
      "kind": "Property",
      "preferredName": "Point in Time",
      "description": "ISO Calendar Week of the given time series entry. Must be given as date of the monday in the week."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#actualCapacity",
      "label": "actualCapacity",
      "kind": "Property",
      "preferredName": "Actual Capacity",
      "description": "The actual capacity is the realistically planned output per calendar week and material for a specific customer in a specific unit of measure, considering all positive or negative impacts on this capacity."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#maximumCapacity",
      "label": "maximumCapacity",
      "kind": "Property",
      "preferredName": "Maximum Capacity",
      "description": "The supplier maximum capacity is the maximal available output per calendar week and material for a specific customer in a specific unit of measure. The maximum capacity thereby restricts the flexible capacity, as the flexible capacity is obtained from the difference of a suppliers maximum capacity minus actual capacity."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#deltaProductionResult",
      "label": "deltaProductionResult",
      "kind": "Property",
      "preferredName": "Delta Production Result",
      "description": "Delta related to the aggregated material demand after pre-/post production calculation the supplier wants to send to the customer. Can be positive and negative."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#agreedCapacity",
      "label": "agreedCapacity",
      "kind": "Property",
      "preferredName": "Agreed Capacity",
      "description": "The agreed capacity of a supplier for a specific customer material(s) within a capacity group. The agreed capacity MUST NOT constitute a legal obligation to deliver."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#startReferenceDateTime",
      "label": "startReferenceDateTime",
      "kind": "Property",
      "preferredName": "Start Reference Date Time",
      "description": "Point in time when the measurement starts on supplier side. It needs to be a point in time after the receival of active flag.\nThis point in time marks the beginning of the first reporting interval. It is also the time of the first week for the rolling sub horizons for alert generation."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#measurementInterval",
      "label": "measurementInterval",
      "kind": "Property",
      "preferredName": "Measurement Interval",
      "description": "Indicates the length of intervals in weeks.\nThe first interval starts with the point in time given by the “startReferenceDateTime”. The second interval starts [Value] week (s) after this. And so on."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#rollingHorizonAlertThresholds",
      "label": "rollingHorizonAlertThresholds",
      "kind": "Property",
      "preferredName": "Demand Volatility Subhorizons",
      "description": "Contains the Parameters that define subhorizons in sequence and length to enable different alert thresholds (per week) over time.\nThe total length of the DCM horizon is 104 weeks. It can be split into subhorizons."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#demandCategoryCode",
      "label": "demandCategoryCode",
      "kind": "Property",
      "preferredName": "Demand Category Code",
      "description": "The code identifying a demand category."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#demandCategoryName",
      "label": "demandCategoryName",
      "kind": "Property",
      "preferredName": "Demand Category Name",
      "description": "The name describing a demand category."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#sequenceNumber",
      "label": "sequenceNumber",
      "kind": "Property",
      "preferredName": "Sequence Number",
      "description": "Sequence number of the subhorizon  \n(positive int values)"
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#subhorizonLength",
      "label": "subhorizonLength",
      "kind": "Property",
      "preferredName": "Subhorizon Length",
      "description": "Length of the subhorizon in weeks. (Value must be >= 1) As a subhorizon can not be shorter than one week."
    },
    {
      "id": "urn:samm:io.catenax.week_based_capacity_group:3.0.1#relativePositiveDeviation",
      "label": "relativePositiveDeviation",
      "kind": "Property",
      "preferredName": "Relative Positive Deviation",
